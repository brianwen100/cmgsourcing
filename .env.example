# Apollo.io API key — get from https://app.apollo.io/settings/integrations/api
APOLLO_API_KEY=your_apollo_api_key_here

# Anthropic API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Sheets (service account)
# Path to the service account JSON downloaded from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_JSON=backend/service_account.json
# The long ID in the Google Sheets URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google OAuth2 (Web client — for browser sign-in flow)
# Create at console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Application type: Web application
# Authorised JavaScript origin: http://localhost:5173
# Copy the Client ID below AND into frontend/.env as VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# ── frontend/.env (Vite reads this from the frontend/ directory) ──
# VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
